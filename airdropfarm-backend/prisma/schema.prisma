generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Snapshot {
  id                     String           @id @default(cuid())
  createdAt              DateTime         @default(now())
  sourceRewardTx         String?
  grossRewardLamports    BigInt
  reservedFeeLamports    BigInt
  reservedSafetyLamports BigInt
  buybackLamports        BigInt
  tokenAPoolLamports     BigInt
  tokenBPoolLamports     BigInt
  tokenAMint             String
  tokenBMint             String
  holders                SnapshotHolder[]
  distributions          Distribution[]
}

model SnapshotHolder {
  id           String   @id @default(cuid())
  snapshotId   String
  owner        String
  inTokenA     Boolean
  inTokenB     Boolean
  tokenARaw    String
  tokenBRaw    String
  baseLamports BigInt
  bonusLamports BigInt
  finalLamports BigInt
  bonusApplied Boolean
  snapshot     Snapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId])
  @@index([owner])
}

model Distribution {
  id           String   @id @default(cuid())
  snapshotId   String
  createdAt    DateTime @default(now())
  owner        String
  lamportsSent BigInt
  txSignature  String?
  status       String
  errorMessage String?
  snapshot     Snapshot @relation(fields: [snapshotId], references: [id])

  @@index([snapshotId])
  @@index([owner])
}

model RewardEvent {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  source             String
  sourceTx           String?  @unique
  grossLamports      BigInt
  status             String
  snapshotId         String?
  distributedAt      DateTime?
  notes              String?
}

model JobLock {
  key        String   @id
  lockedAt   DateTime
}